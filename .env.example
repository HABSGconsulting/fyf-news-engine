# Copy this to .env and fill in values
# Never commit .env to Git

GEMINI_API_KEY=your_gemini_api_key_here

CF_R2_ACCESS_KEY_ID=your_r2_access_key
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CF_R2_BUCKET_NAME=fyf-assets
CF_R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com

NEWS_SITE_REPO=HABSGconsulting/fyf-news-site
BLOG_SITE_REPO=HABSGconsulting/fyf-blog
